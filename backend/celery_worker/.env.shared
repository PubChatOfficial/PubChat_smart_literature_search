# -----------------------------------------------------------------------------
# Environment variables for PubMed Meta-Analysis Workflow
#
# Instructions:
# 1. Copy this file to a new file named .env in the same directory.
# 2. Fill in the values for the variables below.
# 3. DO NOT commit the .env file to version control.
# -----------------------------------------------------------------------------

# (Optional but Recommended) Your NCBI API Key for PubMed.
# This provides a higher request rate limit.
# You can obtain one from your NCBI account settings after logging in.
# See: https://www.ncbi.nlm.nih.gov/books/NBK25497/#chapter2.Getting_an_API_Key
# -----------------------------------------------------------------------------
# Workflow Configuration
# -----------------------------------------------------------------------------

# AI Provider - 支持数字或字符串格式
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ 国际主流                                                                     │
# │   1=gemini (Google), 2=claude (Anthropic), 3=openai, 4=deepseek, 5=grok     │
# │ 国内厂商                                                                     │
# │   6=qwen (通义千问), 7=moonshot (Kimi), 8=glm (智谱), 9=baichuan, 10=yi       │
# │ 聚合平台                                                                     │
# │   11=openrouter, 12=groq, 13=siliconflow, 14=together, 15=fireworks         │
# │ 其他                                                                        │
# │   16=mistral, 17=perplexity, 18=cohere                                      │
# │ 本地模型                                                                     │
# │   19=ollama, 20=lmstudio, 21=gcli2api                                       │
# └─────────────────────────────────────────────────────────────────────────────┘
# 示例: AI_PROVIDER=1 或 AI_PROVIDER=gemini (两种格式均可)
# AI_PROVIDER='gemini'

#Maximum number of search refinement attempts
MAX_REFINEMENT_ATTEMPTS=30

#Minimum number of studies to find before stopping
MIN_STUDY_THRESHOLD=100

# Maximum number of parallel AI workers for article screening
AI_MAX_WORKERS=60

#Output language: 1=中文, 2=English, 3=Español, 4=Français, 5=Português, 6=Italiano, 7=Deutsch, 8=Русский
OUTPUT_LANGUAGE='zh'

# Batch size for processing PMIDs
BATCH_SIZE=600

# 去数据库请求API的配置文件
BASE_URL_API =  http://api-server:8000/


# UNPAYWALL邮箱（因为每个邮箱只能每天100000篇上限）
UNPAYWALL_EMAILS=research1@pubchat.org,research2@pubchat.org,research3@pubchat.org,research4@pubchat.org,research5@pubchat.org,research6@pubchat.org,research7@pubchat.org,research8@pubchat.org,research9@pubchat.org,research10@pubchat.org,research11@pubchat.org,research12@pubchat.org,research13@pubchat.org,research14@pubchat.org,research15@pubchat.org,research16@pubchat.org,research17@pubchat.org,research18@pubchat.org,research19@pubchat.org,research20@pubchat.org,research21@pubchat.org,research22@pubchat.org,research23@pubchat.org,research24@pubchat.org,research25@pubchat.org,research26@pubchat.org,research27@pubchat.org,research28@pubchat.org,research29@pubchat.org,research30@pubchat.org,research31@pubchat.org,research32@pubchat.org,research33@pubchat.org,research34@pubchat.org,research35@pubchat.org,research36@pubchat.org,research37@pubchat.org,research38@pubchat.org,research39@pubchat.org,research40@pubchat.org,research41@pubchat.org,research42@pubchat.org,research43@pubchat.org,research44@pubchat.org,research45@pubchat.org,research46@pubchat.org,research47@pubchat.org,research48@pubchat.org,research49@pubchat.org,research50@pubchat.org,research51@pubchat.org,research52@pubchat.org,research53@pubchat.org,research54@pubchat.org,research55@pubchat.org,research56@pubchat.org,research57@pubchat.org,research58@pubchat.org,research59@pubchat.org,research60@pubchat.org,research61@pubchat.org,research62@pubchat.org,research63@pubchat.org,research64@pubchat.org,research65@pubchat.org,research66@pubchat.org,research67@pubchat.org,research68@pubchat.org,research69@pubchat.org,research70@pubchat.org,research71@pubchat.org,research72@pubchat.org,research73@pubchat.org,research74@pubchat.org,research75@pubchat.org,research76@pubchat.org,research77@pubchat.org,research78@pubchat.org,research79@pubchat.org,research80@pubchat.org,research81@pubchat.org,research82@pubchat.org,research83@pubchat.org,research84@pubchat.org,research85@pubchat.org,research86@pubchat.org,research87@pub